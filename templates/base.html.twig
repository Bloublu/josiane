<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}{% endblock %}</title>
        <link rel="stylesheet" type="text/css" href="{{ asset('css/mycss.css') }}"/>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta2/css/all.min.css" integrity="sha512-YWzhKL2whUzgiheMoBFwW8CKV4qpHQAEuvilg9FAn5VJUDwKZZxkJNuGM4XkWuk94WCrrwslk8yWNGmY1EduTA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
        <link rel="icon" href="{{ asset('images/icone.jpg') }}">


    </head>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-success">
            <div class="container px-3">
                <img style="height:80px; width: 100px;"  src="{{ asset('images/Mascotte.jpg') }}" alt="mascotte">
                <a class="navbar-brand" href="#">Josiane</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
                <div class="collapse navbar-collapse" id="navbarSupportedContent">

                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link"
                               aria-current="page"
                               href="{{ path('accueil') }}">Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="{{ path('travaux') }}">Mon Poulailler
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               aria-current="page"
                               href="{{ path('travaux') }}">Astuce - Bien Etre
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               aria-current="page"
                               href="{{ path('travaux') }}">Nom Poule - Coq
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               aria-current="page"
                               href="{{ path('travaux') }}">Partages
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               aria-current="page"
                               href="{{ path('travaux') }}">Recettes
                            </a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>

        {# read and display all flash messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash-{{ label }} container-fluid">
                    <div class="row">
                        <div class="offset-2 col-9">
                            <h3>{{ message }}<img style="width: 80px; height: 80px;" src="#" alt="logo succes"></h3>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}

    </header>
    <body>
        {% block body %}{% endblock %}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
        <!-- Footer -->
        <div class="container-expand-lg">
            <footer class="footer footer-expand-lg py-4 bg-dark mt-3">
                <div class="container px-4 px-lg-5"><p class="m-0  text-center text-white">Copyright &copy; Your Website 2021</p></div>
            </footer>
        </div>
    </body>
</html>
